{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the application",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["userId", "email"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "An income or expense transaction",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "category": { "type": "string" },
        "date": { "type": "string" },
        "type": { "type": "string" },
        "description": { "type": "string" },
        "createdAt": { "type": "string", "description": "Timestamp" }
      },
      "required": ["userId", "amount", "type", "date"]
    },
    "Debt": {
      "title": "Debt",
      "description": "A user's debt",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "bank": { "type": "string" },
        "type": { "type": "string" },
        "total": { "type": "number" },
        "remaining": { "type": "number" },
        "installments": { "type": "string" },
        "status": { "type": "string" },
        "interest": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["userId", "bank", "total", "remaining"]
    },
    "Goal": {
      "title": "Goal",
      "description": "A user's financial goal",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "target": { "type": "number" },
        "current": { "type": "number" },
        "label": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["userId", "title", "target", "current"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "/transactions/{transactionId}": {
      "schema": { "$ref": "#/entities/Transaction" },
      "description": "Incomes and expenses"
    },
    "/debts/{debtId}": {
      "schema": { "$ref": "#/entities/Debt" },
      "description": "User debts"
    },
    "/goals/{goalId}": {
      "schema": { "$ref": "#/entities/Goal" },
      "description": "Financial goals"
    }
  }
}
